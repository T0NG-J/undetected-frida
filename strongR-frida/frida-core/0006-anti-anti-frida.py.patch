index 0000000..5e91595
--- /dev/null
+++ b/src/anti-anti-frida.py
@@ -0,0 +1,60 @@
+#!/usr/bin/env python
+"""
+Patch a Frida binary to strip well-known Frida symbols/strings and bypass
+anti-Frida detection. Requires: pip install lief (Python 3.8+, needs `sed`).
+
+Works on any Frida ELF/Mach-O — frida-agent, frida-gadget (.so), AND the
+frida-server binary — since they all embed the same frida-gum/GLib signatures.
+NOTE: fully cleans frida-agent/frida-gadget, but the LIEF symbol/.rodata patches
+don't stick on frida-server (its `sed` strings get patched, but signatures like
+`FridaScriptEngine` / `frida_agent_main` survive — patch those separately).
+
+Usage:  python anti-anti-frida.py <frida-agent.so | frida-gadget.so | frida-server>
+
+Patches the file IN PLACE, so run it on a COPY, e.g.:
+    cp frida-gadget.so frida-gadget-patched.so
+    python anti-anti-frida.py frida-gadget-patched.so
+"""
+import lief
+import sys
+import random
+import string
+import os
+if __name__ == "__main__":
+    input_file = sys.argv[1]
+    print(f"[*] Patch frida-agent: {input_file}")
+    random_name = "".join(random.sample(string.ascii_uppercase+string.ascii_lowercase, 5))
+    print(f"[*] Patch `frida` to `{random_name}``")
+    binary = lief.parse(input_file)
+    if not binary:
+        exit()
+    for symbol in binary.symbols:
+        if symbol.name == "frida_agent_main":
+            symbol.name = "main"
+        if "frida" in symbol.name:
+            symbol.name = symbol.name.replace("frida", random_name)
+        if "FRIDA" in symbol.name:
+            symbol.name = symbol.name.replace("FRIDA", random_name)
+
+    [
+        (
+            print(f"section={section.name} offset={hex(section.file_offset + addr)} {patch_str} -> {''.join(list(patch_str)[::-1])}"),
+            binary.patch_address(section.file_offset + addr, [ord(n) for n in list(patch_str)[::-1]])  # not sure if reversing a string can be considered sufficient
+        ) for section in binary.sections if section.name == ".rodata"
+        for patch_str in ["FridaScriptEngine", "GLib-GIO", "GDBusProxy", "GumScript"]  # 字符串特征修改 尽量与源字符一样
+        for addr in section.search_all(patch_str)  # Patch 内存字符串
+    ]
+
+    binary.write(input_file)
+
+    for i in ["gum-js-loop", "gmain", "gdbus"]:  # comprehension with walrus notation? needs py3.8, tho
+        random_name = "".join(random.sample(string.ascii_lowercase+string.ascii_uppercase, len(i)))
+        print(f"[*] Patch `{i}` to `{random_name}`")
+        inplace = "-i ''" if sys.platform == "darwin" else "-i"
+        os.system(f"LC_ALL=C sed {inplace} 's/{i}/{random_name}/g' {input_file}")
+
+    for old, new in [("frida-agent", "fradi-agent"), ("re.frida.server", "re.fradi.server")]:
+        print(f"[*] Patch `{old}` to `{new}`")
+        inplace = "-i ''" if sys.platform == "darwin" else "-i"
+        pattern = old.replace(".", r"\.")
+        os.system(f"LC_ALL=C sed {inplace} 's/{pattern}/{new}/g' {input_file}")
\ No newline at end of file
